# ── Database (SQLite) ─────────────────────────────────────────
# Path ภายใน Container ที่เก็บ database file
DB_PATH=/app/data/booking.db

# ── Backend ───────────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=5000
HOST_BACKEND_PORT=5000

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=3000
HOST_FRONTEND_PORT=3000
